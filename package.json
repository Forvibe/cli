{
  "name": "@forvibe/cli",
  "version": "0.1.0",
  "description": "Forvibe CLI - AI-powered project analyzer for App Store automation",
  "type": "module",
  "bin": {
    "forvibe": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm publish --access public",
    "release:dry": "npm run build && npm publish --access public --dry-run"
  },
  "keywords": [
    "forvibe",
    "app-store",
    "aso",
    "cli",
    "ai",
    "automation"
  ],
  "author": "Forvibe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forvibe/cli.git"
  },
  "homepage": "https://forvibe.com",
  "bugs": {
    "url": "https://github.com/forvibe/cli/issues"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "plist": "^3.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/plist": "^3.0.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ]
}
